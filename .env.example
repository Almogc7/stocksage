# StockSage — environment variable template
#
# HOW TO USE:
#   cp .env.example .env
#   Edit .env with your real values.
#
# SECURITY RULES:
#   - NEVER put real credentials in this file (.env.example is tracked by Git)
#   - NEVER commit .env to version control (it is already listed in .gitignore)
#   - If you accidentally commit real credentials here, rotate them immediately
#   - This file must contain only placeholder strings, never real tokens or IDs

# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot token from @BotFather (format: 1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx)
TELEGRAM_TOKEN=your-telegram-bot-token-here

# Your personal Telegram chat ID — find it via @userinfobot or @getidsbot.
# Used to send outbound alert messages from the bot.
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# Comma-separated list of Telegram chat IDs allowed to issue bot commands.
# For a personal bot: set this to the same numeric value as TELEGRAM_CHAT_ID.
# Multiple users: AUTHORIZED_CHAT_IDS=111111111,222222222
# If left unset, StockSage falls back to TELEGRAM_CHAT_ID automatically.
AUTHORIZED_CHAT_IDS=your-authorized-chat-id-here

# ── Optional API keys (reserved for future features) ─────────────────────────
# Leave blank if not using these services.
ALPHA_VANTAGE_KEY=
NEWS_API_KEY=
ANTHROPIC_API_KEY=
