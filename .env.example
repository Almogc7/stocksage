# StockSage — environment variable template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_TOKEN=your-telegram-bot-token-here

# Your personal Telegram chat ID (find it via @userinfobot or @getidsbot).
# This is used to send outbound alert messages.
TELEGRAM_CHAT_ID=123456789

# Comma-separated list of Telegram chat IDs allowed to issue bot commands.
# For a personal bot, set this to the same value as TELEGRAM_CHAT_ID.
# Multiple users: AUTHORIZED_CHAT_IDS=111111111,222222222
# If left unset, StockSage falls back to TELEGRAM_CHAT_ID automatically.
AUTHORIZED_CHAT_IDS=123456789

# ── Optional API keys (unused in current version) ────────────────────────────
ALPHA_VANTAGE_KEY=
NEWS_API_KEY=
ANTHROPIC_API_KEY=
